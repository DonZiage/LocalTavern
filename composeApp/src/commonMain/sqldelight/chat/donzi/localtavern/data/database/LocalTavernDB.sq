CREATE TABLE CharacterEntity (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    name TEXT NOT NULL,
    description TEXT,
    personality TEXT,
    scenario TEXT,
    firstMes TEXT,
    mesExample TEXT,
    creatorNotes TEXT,
    systemPrompt TEXT,
    altGreetings TEXT,
    avatarData BLOB,
    isAssistant INTEGER NOT NULL DEFAULT 0
);

-- Queries
insertCharacter:
INSERT INTO CharacterEntity(name, description, personality, scenario, firstMes, mesExample, creatorNotes, systemPrompt, altGreetings, avatarData, isAssistant)
VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?);

lastInsertId:
SELECT last_insert_rowid();

selectAllCharacters:
SELECT * FROM CharacterEntity ORDER BY isAssistant DESC, name ASC;

selectAssistant:
SELECT * FROM CharacterEntity WHERE isAssistant = 1 LIMIT 1;

updateCharacter:
UPDATE CharacterEntity
SET name = ?,
    description = ?,
    personality = ?,
    scenario = ?,
    firstMes = ?,
    systemPrompt = ?,
    altGreetings = ?,
    avatarData = ?
WHERE id = ?;

deleteCharactersByIds:
DELETE FROM CharacterEntity WHERE id IN ?;

-- Your Personas (User profiles)
CREATE TABLE PersonaEntity (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    name TEXT NOT NULL,
    description TEXT,
    avatarData BLOB
);

-- Chat Sessions (Groups messages together)
CREATE TABLE ChatSession (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    characterId INTEGER NOT NULL,
    personaId INTEGER NOT NULL,
    title TEXT,
    lastTimestamp INTEGER NOT NULL
);

-- The Messages
CREATE TABLE MessageEntity (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    sessionId INTEGER NOT NULL,
    role TEXT NOT NULL, -- "user" or "assistant"
    content TEXT NOT NULL,
    timestamp INTEGER NOT NULL
);

insertPersona:
INSERT INTO PersonaEntity(name, description, avatarData) VALUES (?, ?, ?);

selectAllPersonas:
SELECT * FROM PersonaEntity ORDER BY name ASC;

selectPersonaById:
SELECT * FROM PersonaEntity WHERE id = ?;

updatePersona:
UPDATE PersonaEntity
SET name = ?,
    description = ?,
    avatarData = ?
WHERE id = ?;

deletePersona:
DELETE FROM PersonaEntity WHERE id = ?;

selectMessagesBySession:
SELECT * FROM MessageEntity WHERE sessionId = ? ORDER BY timestamp ASC;

insertMessage:
INSERT INTO MessageEntity(sessionId, role, content, timestamp) VALUES (?, ?, ?, ?);

updateMessageContent:
UPDATE MessageEntity SET content = ? WHERE id = ?;

deleteMessage:
DELETE FROM MessageEntity WHERE id = ?;

selectLastSessionForCharacter:
SELECT * FROM ChatSession WHERE characterId = ? ORDER BY lastTimestamp DESC LIMIT 1;

insertChatSession:
INSERT INTO ChatSession(characterId, personaId, title, lastTimestamp) VALUES (?, ?, ?, ?);

-- API Connections
CREATE TABLE ApiConnection (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    provider TEXT NOT NULL, -- "OpenAI", "Anthropic", etc.
    name TEXT NOT NULL,     -- User-defined name for this connection
    baseUrl TEXT,
    apiKey TEXT,
    model TEXT,
    isActive INTEGER NOT NULL DEFAULT 0,
    isChatCompletion INTEGER NOT NULL DEFAULT 1,
    lastUsed INTEGER DEFAULT 0, -- Timestamp of last use
    temperature REAL NOT NULL DEFAULT 1.0,
    topP REAL NOT NULL DEFAULT 1.0,
    topK INTEGER NOT NULL DEFAULT 0,
    presencePenalty REAL NOT NULL DEFAULT 0.0,
    frequencyPenalty REAL NOT NULL DEFAULT 0.0,
    contextLimit INTEGER NOT NULL DEFAULT 4096,
    responseLimit INTEGER NOT NULL DEFAULT 0,
    displayOrder INTEGER NOT NULL DEFAULT 0
);

selectAllApiConnections:
SELECT * FROM ApiConnection ORDER BY displayOrder ASC;

insertApiConnection:
INSERT INTO ApiConnection(
    provider, name, baseUrl, apiKey, model, isActive, isChatCompletion, lastUsed,
    temperature, topP, topK, presencePenalty, frequencyPenalty, contextLimit, responseLimit, displayOrder
)
VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?);

updateApiConnection:
UPDATE ApiConnection
SET provider = ?,
    name = ?,
    baseUrl = ?,
    apiKey = ?,
    model = ?,
    isActive = ?,
    isChatCompletion = ?,
    lastUsed = ?,
    temperature = ?,
    topP = ?,
    topK = ?,
    presencePenalty = ?,
    frequencyPenalty = ?,
    contextLimit = ?,
    responseLimit = ?,
    displayOrder = ?
WHERE id = ?;

deleteApiConnection:
DELETE FROM ApiConnection WHERE id = ?;

setActiveApiConnection:
UPDATE ApiConnection SET isActive = 0;

updateActiveApiConnection:
UPDATE ApiConnection SET isActive = 1, lastUsed = ? WHERE id = ?;

selectActiveApiConnection:
SELECT * FROM ApiConnection WHERE isActive = 1 LIMIT 1;

selectLastUsedApiConnection:
SELECT * FROM ApiConnection ORDER BY lastUsed DESC LIMIT 1;

updateApiConnectionDisplayOrder:
UPDATE ApiConnection SET displayOrder = ? WHERE id = ?;

-- App Settings
CREATE TABLE AppSettings (
    id INTEGER PRIMARY KEY CHECK (id = 1) DEFAULT 1,
    isDarkMode INTEGER NOT NULL DEFAULT 1,
    activePersonaId INTEGER
);

getAppSettings:
SELECT * FROM AppSettings WHERE id = 1;

updateDarkMode:
UPDATE AppSettings SET isDarkMode = ? WHERE id = 1;

updateActivePersonaId:
UPDATE AppSettings SET activePersonaId = ? WHERE id = 1;

insertDefaultSettings:
INSERT OR IGNORE INTO AppSettings(id, isDarkMode, activePersonaId) VALUES (1, 1, NULL);
